# SparkLabX - Environment Variables (Vite)
#
# Note: Vite uses VITE_ prefix instead of REACT_APP_
# These variables are embedded at BUILD TIME, not runtime
# For runtime config, use public/env-config.js (injected by Kubernetes)

# API Gateway URL (optional - auto-detected if not set)
# Development: http://localhost:8000
# LH01: http://lh01:30091
# Production: https://api-gateway.datalakehouse.space
# VITE_API_URL=http://localhost:8000

# Alternative API configuration
# VITE_API_BASE_URL=http://localhost:8000
# VITE_DEV_API_URL=http://localhost:8000
# VITE_API_PORT=30091

# Development server port (default: 3000)
# VITE_PORT=3000

# Enable source maps in production (default: false)
# VITE_SOURCEMAP=false

# ─────────────────────────────────────────────────────────────
# RCN Notebook — environment template.
#
# Copy this to `.env` and edit, OR run `./quickstart.sh` to auto-generate
# strong random secrets and boot the stack.
#
# Everything works out of the box except OAuth (Google/Microsoft), which is
# OPTIONAL — leave the client IDs blank to disable those providers and rely
# on the seed-admin username/password login below.
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgres://RCN:RCN@postgres:5432/RCN?sslmode=disable
POSTGRES_DB=RCN
POSTGRES_USER=RCN
POSTGRES_PASSWORD=RCN

# ── JWT signing key + AES-GCM key for stored MinIO secrets ──
# Generate a fresh one: openssl rand -base64 48
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-base64-48
JWT_EXPIRE_MINUTES=480

# ── Seed admin (the first user, auto-promoted to superadmin) ─
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# ── OAuth (OPTIONAL) ────────────────────────────────────────
# Leave blank to disable a provider entirely. With both blank, login is
# username/password only via the seed admin above.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Frontend OAuth — baked into the frontend bundle at build time. Leave blank
# to hide the corresponding "Sign in with …" button on the login page.
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=

# ── Generic OIDC SSO (OPTIONAL) ─────────────────────────────
# Any enterprise IdP via standard OpenID Connect (Keycloak, Okta, Auth0,
# Azure AD, Google, ...). Backend authorization-code flow — endpoints are
# auto-discovered from {issuer}/.well-known/openid-configuration.
# Leave OIDC_ISSUER_URL / OIDC_CLIENT_ID blank to disable (the login page
# hides the SSO button). Unlike Google/Microsoft above, the button is driven
# at RUNTIME via /api/v1/auth/config — no frontend rebuild needed to toggle it.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile
OIDC_PROVIDER_NAME=SSO
# The registered redirect_uri at your IdP (must point back at this app).
OIDC_REDIRECT_URL=http://localhost:3000/api/v1/auth/oidc/callback
OIDC_POST_LOGIN_REDIRECT=http://localhost:3000
# ONLY for setups where the backend can't reach the browser-facing issuer URL
# (e.g. local docker, where the browser uses localhost but the backend uses a
# service name). Leave blank in production.
OIDC_INTERNAL_ISSUER_URL=

# ── Trino (OPTIONAL) ────────────────────────────────────────
# Default Trino JDBC URL injected into every kernel as TRINO_URL, used by the
# built-in trino() notebook helper: trino("SELECT ...") / trino("cat.schema.tbl").
# With SSO enabled, the user's OIDC token is passed through automatically (no
# password). Add the "Trino" connector preset when connecting to load the JDBC
# driver. Leave blank to require an explicit url= in trino(...).
TRINO_URL=
# Backend URL reachable FROM kernel containers; the data helpers call it to
# fetch a fresh OIDC token per query (in-session refresh). Default works for
# docker-compose; set to the in-cluster Service URL for k8s.
KERNEL_CALLBACK_URL=http://RCN-backend:10000

# ── App ─────────────────────────────────────────────────────
CORS_ORIGINS=https://rcn.lakehouse.local

# ── Cloudflare Tunnel (OPTIONAL — for exposing localhost to a public domain)
CLOUDFLARE_TUNNEL_TOKEN=

# ── Storage & Kernel Isolation ──────────────────────────────
# Single shared MinIO bucket; users isolated via per-user prefixes
# (users/<username>/) AND per-user MinIO IAM accounts.
MINIO_WORKSPACE_BUCKET=workspace

# KERNEL_MODE controls how kernel containers are spawned:
#   shared           = ONE Jupyter container for everyone. No isolation.
#                      Cheap; cross-user reads via Spark ARE possible.
#   docker_per_user  = ONE container per user via the host Docker daemon.
#                      Real per-user MinIO IAM isolation locally. Requires
#                      /var/run/docker.sock (already mounted in docker-compose.yml).
#                      SECURITY: docker.sock grants root on the host — only
#                      enable on hosts you trust.
#   k8s_per_user     = ONE pod per user on Kubernetes (production). Backend
#                      must run in-cluster with the RBAC in kubernetes/29-backend-rbac.yaml.
KERNEL_MODE=docker_per_user
KERNEL_POD_IMAGE=ghcr.io/sparklabx/kernel:latest
KERNEL_POD_IDLE_MINUTES=30
KERNEL_POD_MAX_TOTAL=50
KERNEL_DOCKER_NETWORK=RCN_default

# ── Git Integration (Phase 3.3) ───────────────────────────────────
# Enable notebook versioning via Git.
GIT_ENABLED=false
# Path to optional SSH private key for Git operations
GIT_SSH_KEY_PATH=
GIT_AUTHOR_NAME=RCN Notebook
GIT_AUTHOR_EMAIL=notebook@rcn.local

# ── Spark Connect (Phase 3.4) ────────────────────────────────────
# Enable gRPC remote SparkSession support (Spark 3.4+).
SPARK_CONNECT_ENABLED=false
SPARK_CONNECT_ENDPOINT=spark-connect-service
SPARK_CONNECT_PORT=15002

# ── Cost Tracking (Phase 3.6) ────────────────────────────────────
# Default cost rates (VND per unit). Change to your own pricing.
COST_RATE_SPARK_CPU=500.0
COST_RATE_SPARK_MEMORY=100.0
COST_RATE_KERNEL_CPU=1000.0
COST_RATE_KERNEL_MEMORY=200.0
COST_RATE_STORAGE=50.0

# ── MLflow (Phase 5.3) ───────────────────────────────────────
# Enable MLflow tracking proxy (model registry + experiment tracking).
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── AI Assistant (Phase 5.5) ─────────────────────────────────
# Enable AI-powered code assistant in notebooks.
AI_ENABLED=false
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_ENDPOINT=

# ── Delta Lake / Delta Sharing (Phase 5.10) ─────────────────
# Enable Delta Sharing server.
DELTA_SHARING_ENABLED=false
DELTA_SHARING_URL=http://delta-sharing:8080

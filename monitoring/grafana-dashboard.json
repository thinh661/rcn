{
  "dashboard": {
    "title": "RCN Platform — System Overview",
    "uid": "rcn-system",
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "title": "System Health",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "up{job=\"rcn-backend\"}", "legendFormat": "Backend"},
          {"expr": "up{job=\"postgres\"}", "legendFormat": "PostgreSQL"},
          {"expr": "up{job=\"minio\"}", "legendFormat": "MinIO"}
        ],
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "HTTP Requests / sec",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "rate(rcn_http_requests_total[5m])", "legendFormat": "{{method}} {{path}}"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "HTTP Request Duration (p99)",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "histogram_quantile(0.99, sum(rate(rcn_http_request_duration_seconds_bucket[5m])) by (le))"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}
      },
      {
        "title": "Active Kernels",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "rcn_kernel_sessions_active"}
        ],
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 14}
      },
      {
        "title": "Spark Jobs (24h)",
        "type": "piechart",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "sum(rcn_spark_jobs_total) by (status)"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "title": "Go Routines",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "go_goroutines{job=\"rcn-backend\"}"}
        ],
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 18}
      },
      {
        "title": "Memory Usage",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "go_memstats_alloc_bytes{job=\"rcn-backend\"}"}
        ],
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 18}
      }
    ]
  }
}
